generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          Int      @id @default(autoincrement())
  status      String   // "live" | "upcoming" | "past"
  title       String
  type        String
  date        String
  time        String
  location    String
  college     String
  description String
  body        String
  image       String
  gallery     String[]
  galleryUrl  String?
  link        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
